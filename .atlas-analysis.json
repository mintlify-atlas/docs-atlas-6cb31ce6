  "keyFeatures": [
    "Interactive AI-powered terminal interface",
    "Built-in tools for file operations, shell commands, and web search",
    "Context-aware with GEMINI.md files",
    "MCP (Model Context Protocol) server integration",
    "Custom slash commands and extensions",
    "Session management and checkpointing",
    "Sandboxed execution for safety",
    "Multiple authentication methods (OAuth, API key, Vertex AI)",
    "Headless mode for automation and scripting",
    "GitHub Actions integration"
  ],
  "publicApiSurface": [
    "gemini (main CLI command)",
    "gemini --model/-m (model selection)",
    "gemini --resume/-r (session resumption)",
    "gemini --sandbox/-s (sandboxed execution)",
    "gemini --prompt/-p (non-interactive mode)",
    "gemini extensions (extension management)",
    "gemini mcp (MCP server configuration)",
    "gemini update (self-update)",
    "/help (show help)",
    "/chat (checkpoint management)",
    "/settings (configuration editor)",
    "/memory (GEMINI.md management)",
    "/tools (list available tools)",
    "/mcp (MCP server management)",
    "/extensions (extension management)",
    "/resume (session browser)",
    "/restore (undo file changes)",
    "@<path> (include file/directory content)",
    "!<command> (execute shell command)"
  ]
